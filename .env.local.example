# Kopier denne filen til .env.local og fyll inn verdiene

# Anthropic API-nøkkel – hentes fra https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Analytics (valgfritt) – sett inn din egen PostHog-nøkkel for å aktivere anonymisert bruksstatistikk.
# Utelates nøkkelen lastes ingen analytics-kode inn. Velg selv provider og region.
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
